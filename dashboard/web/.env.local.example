# ─────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────
# Public anon key — used by browser + server SSR client.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — bypasses RLS. Required by /api/billing/webhook.
# Source: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────────────────────────────────
# Anthropic — server-side fallback for users without their own BYOK key
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────────────────
# Source: Stripe Dashboard → Developers → API keys (use restricted key in prod)
STRIPE_SECRET_KEY=sk_test_...

# Source: Stripe Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Source: Stripe Dashboard → Products → Pro plan → recurring price ID
STRIPE_PRO_PRICE_ID=price_...
